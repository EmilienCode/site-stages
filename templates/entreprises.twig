{% extends "base.twig" %}

{% block title %}Entreprises{% endblock %}

{% block content %}
<link rel="stylesheet" href="assets/css/styleentreprises.css"/>

<h2 class="entreprisestitre">ENTREPRISES</h2>

<div class="progress">
    <div class="progress-bar"></div>
</div>

<div class="outils">
    <section class="Section">
        <div class="InsideSection">
            <form class="GroupeRecherche" method="GET" action="index.php">
                <input type="hidden" name="page" value="entreprises">

                <div class="BoxRechercher">
                    <div class="input1">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
                            <path d="m21 21-4.34-4.34"></path>
                            <circle cx="11" cy="11" r="8"></circle>
                        </svg>
                        <input type="text" name="nom" placeholder="Rechercher par nom d'entreprise..." class="inputTXT" value="{{ nom_search }}">
                    </div>
                    
                    <div>
                        <button type="submit" class="RechercherBTN">Rechercher</button>
                    </div>
                </div>

                <div class="divTrie">
                    <select name="secteur" class="btnTrie selectTrie" onchange="this.form.submit()">
                        <option value="">Tous les secteurs</option>
                        {% for s in secteurs_list %}
                            <option value="{{ s }}" {% if s == secteur_selected %}selected{% endif %}>{{ s }}</option>
                        {% endfor %}
                    </select>

                    <select name="taille" class="btnTrie selectTrie" onchange="this.form.submit()">
                        <option value="">Toutes les tailles</option>
                        <option value="GE" {% if taille_selected == 'GE' %}selected{% endif %}>GE</option>
                        <option value="PME" {% if taille_selected == 'PME' %}selected{% endif %}>PME</option>
                        <option value="ETI" {% if taille_selected == 'ETI' %}selected{% endif %}>ETI</option>
                       
                    </select>
                </div>
            </form>
        </div>
    </section>
</div>

<div class="entreprises-container">
    {% for e in entreprises %}
        <div class="entreprise-card">
            <div class="card-body-content">
                <div class="card-header-simple">
                    <h3 class="entreprise-nom">{{ e.nom_entreprise|default('Nom inconnu') }}</h3>
                    <p class="ville-label">📍 {{ e.ville_entreprise|default('N/A') }}</p>
                </div>

                <div class="details-cache">
                    <div class="details-content">
                        <p class="description">
                            <strong>À propos :</strong><br>
                            {{ e.description_entreprise|default('Aucune description.')|nl2br }}
                        </p>

                        <div class="info-grid">
                            <div class="info-item"><strong>🆔 SIRET :</strong> {{ e.siret_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📞 Tel :</strong> {{ e.telephone_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📧 Mail :</strong> {{ e.email_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📏 Taille :</strong> {{ e.taille_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>💼 Secteur :</strong> {{ e.secteur_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>🌍 Site Web :</strong> {{ e.site_web_entreprise|default('/') }}</div>
                        </div>

                        <div class="links-footer">
                            {% if e.site_web_entreprise is not empty %}
                                <a href="{{ e.site_web_entreprise }}" target="_blank" class="pagination-btn">Site Web</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% else %}
<div class="no-results">
    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="no-results-icon">
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
    </svg>
    <p>Aucune entreprise ne correspond à vos critères de recherche.</p>
    <a href="?page=entreprises" class="btn-reset">Réinitialiser les filtres</a>
</div>
    {% endfor %}
</div>

<div class="pagination">
    {# On stocke les paramètres pour les répercuter sur les liens suivant/précédent #}
    {% set params = "&nom=" ~ nom_search ~ "&taille=" ~ taille_selected ~ "&secteur=" ~ secteur_selected %}
    
    {% if currentPage > 1 %}
        <a href="?page=entreprises&p={{ currentPage - 1 }}{{ params }}" class="pagination-btn">Précédent</a>
    {% endif %}

    {% if currentPage < totalPages %}
        <a href="?page=entreprises&p={{ currentPage + 1 }}{{ params }}" class="pagination-btn">Suivant</a>
    {% endif %}
</div>

<script src="assets/js/scroll-animation.js"></script>
{% endblock %}