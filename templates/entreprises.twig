{% extends "base.twig" %}

{% block title %}Entreprises{% endblock %}

{% block content %}
<link rel="stylesheet" href="assets/css/styleentreprises.css"/>

<h2 class="entreprisestitre">ENTREPRISES</h2>

<div class="progress">
    <div class="progress-bar"></div>
</div>

<div class="outils">
    <section class="Section">
        <div class="InsideSection">
                <form class="GroupeRecherche" method="GET" action="index.php">
                
                    <input type="hidden" name="page" value="offres">

                    <div class="BoxRechercher">
                        <div class="input1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
                                <path d="m21 21-4.34-4.34"></path>
                                <circle cx="11" cy="11" r="8"></circle>
                            </svg>
                            <input type="text" name="metier" placeholder="Métier, compétence..." class="inputTXT" value="{{ GET.metier ?? '' }}">
                        </div>
                        
                        <div class="input2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
                                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            <input type="text" name="ville" placeholder="Ville ou région" class="inputTXT" value="{{ GET.ville ?? '' }}">
                        </div>
                        
                        <div>
                            <button type="submit" class="RechercherBTN">Rechercher</button>
                        </div>
                    </div>

                    <div class="divTrie">
                        

                        <select name="competence" class="btnTrie selectTrie" onchange="this.form.submit()">
                            <option value="">Toutes les compétences</option>
                            {% for comp in competences %}
                                <option value="{{ comp.id_competence }}" {% if comp.id_competence == competence_selected %}selected{% endif %}>
                                    {{ comp.nom_competence }}
                                </option>
                            {% endfor %}
                        </select>

                        <select name="tri" class="btnTrie selectTrie" onchange="this.form.submit()">
                            <option value="recents" {% if tri == 'recents' %}selected{% endif %}>Trier par : Récents</option>
                            <option value="anciens" {% if tri == 'anciens' %}selected{% endif %}>Trier par : Anciens</option>
                            <option value="salaire_asc" {% if tri == 'salaire_asc' %}selected{% endif %}>Salaire : Croissant</option>
                            <option value="salaire_desc" {% if tri == 'salaire_desc' %}selected{% endif %}>Salaire : Décroissant</option>
                        </select>
                    </div>
                </form>
        </div>
    </section>
</div>

<div class="entreprises-container">
    {% for e in entreprises %}
        {# On applique le filtre lower sur les clés si vraiment nécessaire, sinon on utilise e.NOM_ENTREPRISE #}
        <div class="entreprise-card">
            <div class="card-body-content">
                
                <div class="card-header-simple">
                    <h3 class="entreprise-nom">{{ e.nom_entreprise|default('Nom inconnu') }}</h3>
                    <p class="ville-label">📍 {{ e.ville_entreprise|default('N/A') }}</p>
                </div>

                <div class="details-cache">
                    <div class="details-content">
                        <p class="description">
                            <strong>À propos :</strong><br>
                            {{ e.description_entreprise|default('Aucune description.')|nl2br }}
                        </p>

                        <div class="info-grid">
                            <div class="info-item"><strong>🆔 SIRET :</strong> {{ e.siret_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📞 Tel :</strong> {{ e.telephone_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📧 Mail :</strong> {{ e.email_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>📏 Taille :</strong> {{ e.taille_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>💼 Secteur :</strong> {{ e.secteur_entreprise|default('/') }}</div>
                            <div class="info-item"><strong>🌍 Site Web :</strong> {{ e.site_web_entreprise|default('/') }}</div>
                        </div>

                        <div class="links-footer">
                            {% if e.site_web_entreprise is not empty %}
                                <a href="{{ e.site_web_entreprise }}" target="_blank" class="pagination-btn">Site Web</a>
                            {% endif %}
                        </div>
                    </div>
                </div>

            </div>
        </div>
    {% else %}
        <p>Aucune entreprise trouvée.</p>
    {% endfor %}
</div>

<div class="pagination">
    {% if currentPage > 1 %}
        <a href="?page=offres&p={{ currentPage - 1 }}" class="pagination-btn">Précédent</a>
    {% endif %}

    {% if currentPage < totalPages %}
        <a href="?page=offres&p={{ currentPage + 1 }}" class="pagination-btn">Suivant</a>
    {% endif %}
</div>
<script src="assets/js/scroll-animation.js"></script>
{% endblock %}