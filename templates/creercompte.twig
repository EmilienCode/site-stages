{% extends "base.twig" %}

{% block title %}Créer un compte{% endblock %}

{% block content %}

<link rel="stylesheet" href="assets/css/stylelogin.css"/>
    <main class="connexion-container">
    <section class="connexion-card">
        <header class="connexion-header">
            <h1>Créer un compte</h1>
            <p>Créer un compte pour plus de fonctionnalitées</p>
        </header>


        {# Vérification des droits : seul pilote (2) et admin (3) peuvent créer #}
        {% if session.id_role == 2 or session.id_role == 3 %}

        <form class="connexion-form" method="POST" action="index.php?action=inscription_user" onsubmit="return checkForm()">
            <input type="hidden" name="type" value="COMPTE">

            <div class="form-row">
                <div class="form-line">
                    <label for="nom">Nom</label>
                    <input type="text" name="nom" id="nom" placeholder="Zidane" required>
                </div>

                <div class="form-line">
                    <label for="prenom">Prénom</label>
                    <input type="text" name="prenom" id="prenom" placeholder="Zinédine" required>
                </div>
            </div>

            <div class="form-line">
                <label for="username">Email</label>
                <input
                    type="text"
                    name="email"
                    id="username" 
                    placeholder="zizouzidane@gmail.com"
                    required
                />
                <!-- pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"= regex qui vérifie qu'on a un email valide -->
                <span id="error-email" style="color:#914941;"></span>
                
            </div>

            <div class="form-line">
                <label for="password">Définissez un mot de passe   </label>
                <input
                    type="password"
                    name="password"
                    id="password"
                    minlength="8" 
                    pattern="^(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}$" 
                    placeholder="••••••••"
                    required
                /> <!-- (?=.*[A-Z]) → au moins 1 majuscule
                        (?=.*\d) → au moins 1 chiffre
                        (?=.*[^A-Za-z0-9]) → au moins 1 caractère spécial
                        {8,} → 8 caractères minimum-->
                <br>      
                <small class="password-hint">
                     8 caractères minimum, <strong>1 majuscule</strong>, <strong>1 chiffre</strong> et <strong>1 caractère spécial</strong>
                </small>
            </div>

            <div class="form-line">
                <label for="password">Confirmez votre mot de passe</label>
                <input
                    type="password"
                    id="confirm"
                    minlength="8"
                    pattern="^(?=.*[A-Z])(?=.*\d)(?=.*[^A-Za-z0-9]).{8,}$"
                    placeholder="••••••••"
                    required
                />
                <span id="error" style="color:#914941;"></span><br><br>
            </div>

            <!-- BLOC COORDONNÉES -->
            <h3>Coordonnées</h3>

            <div class="form-line">
                <label>Sexe</label>
                <div class="form-row">
                    <label>
                        <input type="radio" name="sexe" value="0" required> M.
                    </label>

                    <label>
                        <input type="radio" name="sexe" value="1"> Mme.
                    </label>
                </div>
            </div>

            <div class="form-line">
                <label>Rôle</label>

                {# ADMIN : peut choisir le rôle #}
                {% if session.id_role == 3 %}
                <div class="form-row">
                    <label>
                        <input type="radio" name="role" value="1" required> Étudiant
                    </label>

                    <label>
                        <input type="radio" name="role" value="2"> Pilote
                    </label>
                </div>

                {# PILOTE : ne peut créer que des étudiants (champ caché) #}
                {% elseif session.id_role == 2 %}
                    <input type="hidden" name="role" value="1">
                    <p><strong>Étudiant</strong></p>
                {% endif %}
            </div>
            
            <div class="form-line">
                <label for="naissance">Date de naissance</label>
                <input
                    type="text"
                    name="date_naissance"
                    id="naissance"
                    placeholder="jj/mm/aaaa"
                    required
                />
            </div>
            <span id="error-date" style="color:#914941;"></span><br><br>

            <div class="form-line">
                <label for="telephone">Téléphone</label>
                <input
                    type="tel"
                    name="telephone"
                    id="telephone"
                    minlength="10"
                    maxlength="10"
                    pattern="[0-9]{10}"
                    placeholder="0606060606"
                    required
                />
            </div>

            <div class="form-line">
                <label for="ville">Ville</label>
                <input
                    type="text"
                    name="ville"
                    id="ville"
                    placeholder="Orléans"
                    required
                />
                <span id="error-ville" style="color:#914941;"></span><br><br>
            </div>

            <button type="submit" class="btn-primary btn-full">
                Créer un compte
            </button>

        </form>

        {% else %}
            <div class="alert error">
                <p>Accès refusé. Vous n'avez pas les permissions nécessaires.</p>
                <a href="/">Retour à l'accueil</a>
            </div>
        {% endif %}
        <script src="assets/js/formulaire.js"></script>
        <div class="connexion-links">
            <a href="index.php?page=afficher_utilisateur">← Retour</a>
        </div>
    </section>
    </main>

{% endblock %}