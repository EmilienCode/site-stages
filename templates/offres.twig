{% extends "base.twig" %}

{% block title %}
Offres
{% endblock %}

{% block content %}
<link rel="stylesheet" href="assets/css/styleoffres.css"/>

<div class="progress">
    <div class="progress-bar"></div>
</div>

<div class="outils" style="padding-top: calc(var(--spacing) * 16);">
    <section class="Section">
        <div class="InsideSection">
                <form class="GroupeRecherche" method="GET" action="index.php">
                
                    <input type="hidden" name="page" value="offres">

                    <div class="BoxRechercher">
                        <div class="input1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
                                <path d="m21 21-4.34-4.34"></path>
                                <circle cx="11" cy="11" r="8"></circle>
                            </svg>
                            <input type="text" name="metier" placeholder="Métier, compétence..." class="inputTXT" value="{{ GET.metier ?? '' }}">
                        </div>
                        
                        <div class="input2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
                                <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"></path>
                                <circle cx="12" cy="10" r="3"></circle>
                            </svg>
                            <input type="text" name="ville" placeholder="Ville ou région" class="inputTXT" value="{{ GET.ville ?? '' }}">
                        </div>
                        
                        <div>
                            <button type="submit" class="RechercherBTN">Rechercher</button>
                        </div>
                    </div>

                    <div class="divTrie">
                        

                        <select name="competence" class="btnTrie selectTrie" onchange="this.form.submit()">
                            <option value="">Toutes les compétences</option>
                            {% for comp in competences %}
                                <option value="{{ comp.id_competence }}" {% if comp.id_competence == competence_selected %}selected{% endif %}>
                                    {{ comp.nom_competence }}
                                </option>
                            {% endfor %}
                        </select>

                        <select name="tri" class="btnTrie selectTrie" onchange="this.form.submit()">
                            <option value="recents" {% if tri == 'recents' %}selected{% endif %}>Trier par : Récents</option>
                            <option value="anciens" {% if tri == 'anciens' %}selected{% endif %}>Trier par : Anciens</option>
                            <option value="salaire_asc" {% if tri == 'salaire_asc' %}selected{% endif %}>Salaire : Croissant</option>
                            <option value="salaire_desc" {% if tri == 'salaire_desc' %}selected{% endif %}>Salaire : Décroissant</option>
                        </select>
                    </div>
                </form>
            <div class="planete"></div>
        </div>
    </section>
</div>

<section class="offres">
    {% for o in offres %}
    <article class="entreprise-card">
        <div class="card-body-content">
            <h3 class="entreprise-nom">{{ o.titre_offre }}</h3>
            <p class="remuneration">🏢 {{ o.nom_entreprise  }} </p>

            <div class="details-cache">
                <div class="details-content">
                    <p class="description">{{ o.description_offre }}</p>
                    <div class="info-grid">
                        <div class="info-item">💰 <strong>Rémunération :</strong> {{ o.remuneration_offre}} €/mois</div>
                        <div class="info-item">📅 <strong>Publié le :</strong> {{ o.date_offre|date("d/m/Y") }}</div>
                    </div>
                    <a href="?page=postuler&id={{ o.id_offre }}" class="RechercherBTN" style="display: block; text-align: center; text-decoration: none;">En savoir plus</a>
                </div>
            </div>
        </div>
    </article>
    {% endfor %}
</section>



<div class="pagination">
    {% if currentPage > 1 %}
        <a href="?page=offres&p={{ currentPage - 1 }}" class="pagination-btn">Précédent</a>
    {% endif %}

    {% if currentPage < totalPages %}
        <a href="?page=offres&p={{ currentPage + 1 }}" class="pagination-btn">Suivant</a>
    {% endif %}
</div>

{% endblock %}