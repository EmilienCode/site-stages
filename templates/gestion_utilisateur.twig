{% extends "base.twig" %}
{% block title %}
Gestion Utilisateur
{% endblock %}
{% block content %}

    <link rel="stylesheet" href="assets/css/root.css"/>
    <link rel="stylesheet" href="assets/css/styleadmin.css"/>

    {% if session.user_id is defined and session.user_id is not null and session.id_role == 2 or session.id_role == 3 %}
    <main class="admin-container">
        <div class="admin-header">
            <h1>Gestion des Utilisateurs</h1>
            <a href="index.php?page=creercompte" class="btn-add">+ Ajouter un utilisateur</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id_utilisateur }}</td>
                        <td>{{ user.nom }}</td>
                        <td>{{ user.prenom }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.nom_role|default('Aucun') }}</td>
                        <td>
                            <a href="index.php?page=modifier_utilisateur&id={{ user.id_utilisateur }}" class="btn-action btn-edit">Modifier</a>
                            <a href="index.php?page=supprimer_utilisateur&id={{ user.id_utilisateur }}" class="btn-action btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">Supprimer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;">Aucun utilisateur trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </main>
    {% else %}
        <div class="alert error">
            <p>Accès refusé. Vous n'avez pas les permissions nécessaires.</p>
            <a href="/">Retour à l'accueil</a>
        </div>
    {% endif %}

{% endblock %}