{% extends "base.twig" %}
{% block title %}
Gestion Utilisateur
{% endblock %}
{% block content %}

    <link rel="stylesheet" href="assets/css/styleadmin.css"/>

    {% if session.user_id is defined and session.user_id is not null and session.id_role == 2 or session.id_role == 3 %}
        <main class="admin-container">
            <div class="admin-header">
                <h1>Gestion des Utilisateurs</h1>
                <a href="index.php?page=creercompte" class="btn-add">+ Ajouter un utilisateur</a>
            </div>
            {% if success == 'created' %}
                <div class="alert success">
                    Utilisateur créé avec succès ✅
                </div>
            {% endif %}

            <form method="GET" action="index.php" class="BoxRechercher">
    <input type="hidden" name="page" value="afficher_utilisateur">

    <div class="input1">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="svgLoop" aria-hidden="true">
            <path d="m21 21-4.34-4.34"></path>
            <circle cx="11" cy="11" r="8"></circle>
        </svg>
        <input type="text" name="nom" placeholder="Rechercher nom ou prénom" class="inputTXT" value="{{ nom_search }}">
    </div>
        
    <div>
        <button type="submit" class="RechercherBTN">Rechercher</button>
    </div>
</form>


            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Nom</th>
                        <th>Prénom</th>
                        <th>Email</th>
                        <th>Rôle</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                        <tr>
                            <td data-label="ID">{{ user.id_utilisateur }}</td>
                            <td data-label="Nom">{{ user.nom }}</td>
                            <td data-label="Prénom">{{ user.prenom }}</td>
                            <td data-label="Email">{{ user.email }}</td>
                            <td data-label="Rôle">{{ user.nom_role|default('Aucun') }}</td>
                            <td>
                                <a href="index.php?page=modifier_utilisateur&id={{ user.id_utilisateur }}" class="btn-action btn-edit">Modifier</a>
                                <a href="index.php?page=supprimer_utilisateur&id={{ user.id_utilisateur }}" class="btn-action btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">Supprimer</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" style="text-align:center;">Aucun utilisateur trouvé.</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </main>
    </div>
    {% else %}
        <div class="alert error">
            <p>Accès refusé. Vous n'avez pas les permissions nécessaires.</p>
            <a href="/">Retour à l'accueil</a>
        </div>
    {% endif %}

{% endblock %}