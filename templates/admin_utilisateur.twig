{% extends "base.twig" %}
{% block title %}
Gestion Admin
{% endblock %}
{% block content %}

    <style>
        .admin-container { max-width: 1000px; margin: 40px auto; padding: 20px; font-family: sans-serif; background: #fff; border-radius: 8px; box-shadow: 0 4px 6px rgba(0,0,0,0.1); }
        .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .btn-add { background-color: #fa8072; color: white; padding: 10px 15px; text-decoration: none; border-radius: 5px; font-weight: bold; }
        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th, .admin-table td { padding: 12px; border: 1px solid #ddd; text-align: left; }
        .admin-table th { background-color: #f4f4f4; }
        .btn-action { padding: 6px 10px; text-decoration: none; color: white; border-radius: 4px; font-size: 14px; margin-right: 5px; }
        .btn-edit { background-color: #007bff; }
        .btn-delete { background-color: #dc3545; }
    </style>

    <main class="admin-container">
        <div class="admin-header">
            <h1>Gestion des Utilisateurs</h1>
            <a href="creercompte.php" class="btn-add">+ Ajouter un utilisateur</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for user in users %}
                    <tr>
                        <td>{{ user.id_utilisateur }}</td>
                        <td>{{ user.nom }}</td>
                        <td>{{ user.prenom }}</td>
                        <td>{{ user.email }}</td>
                        <td>{{ user.nom_role|default('Aucun') }}</td>
                        <td>
                            <a href="modifier_utilisateur.php?id={{ user.id_utilisateur }}" class="btn-action btn-edit">Modifier</a>
                            <a href="supprimer_utilisateur.php?id={{ user.id_utilisateur }}" class="btn-action btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cet utilisateur ?');">Supprimer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" style="text-align:center;">Aucun utilisateur trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </main>

{% endblock %}