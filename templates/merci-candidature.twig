{% extends "base.twig" %}

{% block title %}
Candidature envoyée
{% endblock %}

{% block content %}
<link rel="stylesheet" href="assets/css/stylepostuler.css"/>

<section class="card thank-card">
    <div class="thank-icon">✔</div>

    <h1>Merci pour votre candidature !</h1>

    <p>
        Votre candidature a bien été prise en compte.<br>
        L’entreprise analysera votre profil.
    </p>
</section>

{% if candidature %}
<section class="card" style="max-width:700px;margin:20px auto;">
    <h3 style="margin-bottom:15px;">📄 Récapitulatif de votre candidature</h3>

    <p><strong>Offre :</strong> {{ candidature.titre_offre }}</p>
    <p><strong>Entreprise :</strong> {{ candidature.nom_entreprise }}</p>

    <p><strong>Lettre de motivation :</strong></p>
    <p style="background:#f5f5f5;padding:10px;border-radius:8px;">
        {{ candidature.LM_candidature }}
    </p>

    <p><strong>CV :</strong> 
        <a href="{{ candidature.CV_candidature }}" target="_blank">Voir mon CV</a>
    </p>
</section>
{% endif %}

<div class="thank-actions">
    <a href="?page=accueil" class="btn btn-secondary">Retour à l’accueil</a>
    <a href="?page=offres" class="btn btn-primary">Voir d’autres offres</a>
</div>

{% endblock %}