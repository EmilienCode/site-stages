{% extends "base.twig" %}
{% block title %}
Gestion Entreprises
{% endblock %}
{% block content %}

    <link rel="stylesheet" href="assets/css/styleadmin.css"/>

    {% if session.user_id is defined and session.user_id is not null and (session.id_role == 2 or session.id_role == 3) %}
    <main class="admin-container">
        <div class="admin-header">
            <h1>Gestion des Entreprises</h1>
            <a href="index.php?page=creerentreprise" class="btn-add">+ Ajouter une entreprise</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Siret</th>
                    <th>Nom entreprise</th>
                    <th>Email</th>
                    <th>Secteur</th>
                    <th>Ville</th>
                    <th>Note</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for ent in entreprise %}
                    <tr>
                        <td data-label="Siret">{{ ent.siret_entreprise }}</td>
                        <td data-label="Nom de l'entreprise">{{ ent.nom_entreprise }}</td>
                        <td data-label="Email">{{ ent.email_entreprise }}</td>
                        <td data-label="Secteur">{{ ent.secteur_entreprise }}</td>
                        <td data-label="Ville">{{ ent.ville_entreprise }}</td>
                        <td data-label="Note">
                            {% if ent.note_evaluation is not null %}
                                {{ent.note_evaluation}} / 5
                            {%else%}
                                Aucune
                            {% endif %}
                        </td>

                        <td>
                            <a href="index.php?page=modifier_entreprise&id={{ ent.siret_entreprise }}" class="btn-action btn-edit">Modifier</a>
                            <a href="index.php?page=supprimer_entreprise&id={{ ent.siret_entreprise }}" class="btn-action btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette entreprise ?');">Supprimer</a>
                            <a href="index.php?page=evaluer_entreprise&id={{ ent.siret_entreprise }}" class="btn-action btn-note">Evaluer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" style="text-align:center;">Aucune entreprises trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </main>
    {% else %}
        <div class="alert error">
            <p>Accès refusé. Vous n'avez pas les permissions nécessaires.</p>
            <a href="/">Retour à l'accueil</a>
        </div>
    {% endif %}

{% endblock %}