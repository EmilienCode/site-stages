{% extends "base.twig" %}
{% block title %}
Gestion Offres
{% endblock %}
{% block content %}

    <link rel="stylesheet" href="assets/css/styleadmin.css"/>

    {% if session.user_id is defined and session.user_id is not null and session.id_role == 2 or session.id_role == 3 %}
    <main class="admin-container">
        <div class="admin-header">
            <h1>Gestion des Offres de {{nom_entreprise}}</h1>
            <a href="index.php?page=creeroffre" class="btn-add">+ Ajouter une offre</a>
        </div>

        <table class="admin-table">
            <thead>
                <tr>
                    <th>Id</th>
                    <th>Titre</th>
                    <th>Description</th>
                    <th>Remuneration</th>
                    <th>Date</th>
                    <th>Lieu</th>
                    <th>Durée</th>
                    <th>Domaine</th>
                    <th>Nombres de vues</th>
                    <th>Nombres de postulants</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                {% for offre in offres %}
                    <tr>
                        <td data-label="ID">{{ offre.id_offre }}</td>
                        <td data-label="Titre">{{ offre.titre_offre }}</td>
                        <td data-label="Description">{{ offre.description_offre }}</td>
                        <td data-label="Rémunération">{{ offre.remuneration_offre }}</td>
                        <td data-label="Date">{{ offre.date_offre }}</td>
                        <td data-label="Lieu">{{ offre.lieu_offre }}</td>
                        <td data-label="Durée">{{ offre.duree_formation_offre }}</td>
                        <td data-label="Domaine">{{ offre.domaine_requis_offre }}</td>
                        <td data-label="Nom entreprise">{{ offre.nom_entreprise }}</td>
                        <td data-label="Nombres de vues">{{ offre.nombredevues }}</td>
                        <td data-label="Nombres de postulants">{{ offre.nombredepostulants }}</td>
                        <td>
                            <a href="index.php?page=modifier_offre&id={{ offre.id_offre }}" class="btn-action btn-edit">Modifier</a>
                            <a href="index.php?page=supprimer_offre&id={{ offre.id_offre }}" class="btn-action btn-delete" onclick="return confirm('Êtes-vous sûr de vouloir supprimer cette offre ?');">Supprimer</a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="12" style="text-align:center;">Aucune offres trouvé.</td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </main>
    {% else %}
        <div class="alert error">
            <p>Accès refusé. Vous n'avez pas les permissions nécessaires.</p>
            <a href="/">Retour à l'accueil</a>
        </div>
    {% endif %}

{% endblock %}