

{% block content %}
<link rel="stylesheet" href="assets/css/powerpoint.css"/>

<div class="powerpoint-wrapper">
    
    <section class="scene hero-scene">
        <h1 class="hero-title">Soutenance Site Web <br><span class="highlight">CESITONSTAGE</span></h1>
        <p class="hero-subtitle">Fait par Mathéo GOAOC, Tom ROMANIN, Charles DEVINES, Emilien ROUSSEAU</p>
        <div class="scroll-indicator">↓ Scrollez pour le Sommaire ↓</div>
    </section>

    <section class="scene text-reveal-scene">
        <div class="text-container">
            <h2 class="reveal-text">01. Contexte</h2>
            <h2 class="reveal-text">02. Objectifs</h2>
            <h2 class="reveal-text">03. Contraintes et cahier des charges</h2>
            <h2 class="reveal-text">04. Répartition du travail</h2>
            <h2 class="reveal-text">05. Architecture projet </h2>
            <h2 class="reveal-text">06. MVC et MCD </h2>
        </div>
    </section>

    <section class="scene horizontal-scene">
        <div class="horizontal-container">
            <div class="panel">
                    <div class="panel-content">
                        <div class="panel-text">
                            <h3>01. Contexte</h3>
                            <br>
                            <p> <strong>Client :</strong> CESI</p>
                            <p> <strong>Besoin :</strong> Répertoire d'offres de stages pour les étudiants</p>
                            <p> <strong>Solution :</strong> Site web connecté et sécurisé</p>
                            <p> <strong>Projet :</strong> CESITONSTAGE</p>
                        </div>
                    <div class="panel-image">
                        <img src="./includes/image/imgcontexte.png" alt="image d'un site">
                    </div>
                </div>
                </div>

                <div class="panel">
                    <div class="panel-content">
                        <div class="panel-text">
                            <h3>02. Objectifs</h3>
                            <br>
                            <p> <strong>Site sécurisé:</strong> Protection des données et du site, compte admin, pilotes, etudiants et anonymes.  </p>
                            <p> <strong>Recherche ciblée :</strong> Tableaux de bord interactifs selon compétences, lieux etc.</p>
                            <p> <strong>Ergonomie :</strong> Compatible tout formats (media querries) </p>
                        </div>
                        <div class="panel-image">
                        <img src="./includes/image/imgobjectif.png" alt="image des objectifs ">
                        </div>
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-content">
                        <div class="panel-text">
                            <h3>04. Cahier des charges (matrice permission) </h3>
                            <br>
                            <h3>04. Matrice des Permissions</h3>
                                <br>
                                <p> <strong>Administrateur :</strong> Contrôle total Gestion globale des pilotes, étudiants, entreprises et offres</p>
                                <p> <strong>Pilote :</strong> Gestion opérationnelle Administration des étudiants, des entreprises et des offres</p>
                                <p> <strong>Étudiant :</strong> Accès utilisateur Authentification, recherche et peut postuler aux offres + wishlist. </p>
                                <p> <strong>Anonyme :</strong> Accès visiteur Simple consultation publique des offres et entreprises sans modification avec filtres etc. </p>
                        </div>
                        <div class="panel-image">
                        <img src="./includes/image/cdc.png" alt="image du cahier des charges ">
                        </div>
                    </div>
            </div>
        </div>
    </section>

    <section class="diagrams-scene-vertical">
        <div class="diagrams-header">
            <h2>04. Diagrammes de répartition</h2>
            <p>Outils de répartition du travail</p>
        </div>
        
        <div class="diagram-list">
            <div class="diagram-item">
                <h3>Diagramme Gantt simplifié</h3>
                <div class="diag-img-container">
                    <img src="./includes/image/chronologie.png" alt="Chronologie">
                </div>
            </div>

            <div class="diagram-item">
                <h3>Trello Répartition des tâches</h3>
                <div class="diag-img-container">
                    <img src="./includes/image/trello.png" alt="trello"> </div>
            </div>

            <div class="diagram-item">
                <h3>Git-Hub</h3>
                <div class="diag-img-container">
                    <img src="./includes/image/git.png" alt="Github"> </div>
            </div>
        </div>
    </section>
    <section class="scene epic-scene-1">
        <div class="epic-container">
            <h2 class="bg-title">INNOVATION</h2>
            <div class="box-3d-wrapper">
                <div class="layer layer-back">Back-End<br>(BDD, API)</div>
                <div class="layer layer-front">Interface<br>(Front-End)</div>
                <div class="layer layer-mid">Logique Métier<br>(Core)</div>
            </div>
            <p class="epic-desc">Nous avons choisi une architecture par couches pour mieux répartir et optimiser notre travail</p>
        </div>
    </section>

    <section class="scene mvc-mcd-scene">
        <div class="tech-panel mvc-panel">
            <h3 class="tech-title">Modèle MVC</h3>
            <p class="tech-desc">Séparation claire entre les données (Model), l'interface (View) et la logique (Controller).</p>
            <div class="tech-img-large"><img src="./includes/image/MVC.png" alt="MVC"></div>
        </div>
        <div class="tech-panel mcd-panel">
            <h3 class="tech-title">Modèle Conceptuel (MCD)</h3>
            <p class="tech-desc">Structure relationnelle optimisée pour garantir l'intégrité de notre base de données.</p>
            <div class="tech-img-large mcd-glow"><img src="./includes/image/mcd.png" alt="MCD"></div>
        </div>
    </section>

    <section class="scene experience-wow-scene">
        <h2 class="bg-massive-text">VOICI</h2>
        <div class="reveal-portal">
            <div class="portal-content">
                <h3 class="brand-title">CESITONSTAGE</h3>
                <p class="brand-slogan">Stage : Trouvé, Stress : Oublié.</p>
            </div>
        </div>
    </section>

    <section class="scene final-smooth-scene">
        <div class="grid-overlay"></div>
        <div class="smooth-words-container">
            <div class="smooth-word word-1">PLACE</div>
            <div class="smooth-word word-2">À LA</div>
            <div class="smooth-word word-3 highlight-glow">DÉMONSTRATION</div>
        </div>
        <a href="?page=accueil" class="btn-retour final-btn">Découvrir le site</a>
    </section>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
<script src="assets/js/powerpoint.js"></script>
{% endblock %}